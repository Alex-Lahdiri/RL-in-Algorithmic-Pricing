import pickle
from pathlib import Path
import warnings
warnings.filterwarnings("ignore", category=RuntimeWarning)

# Load the pair classifier
with open("trained_classifier_pair.pkl", "rb") as f:
    bundle = pickle.load(f)
clf_pair = bundle["model"]
PAIR_FEATURE_COLS = bundle["feature_cols"]

# Load and filter panel
SNAPSHOT_DIR = Path("fuel_snapshots")
paths = sorted(SNAPSHOT_DIR.glob("snapshot_*.csv"))
panel = pd.concat([pd.read_csv(p) for p in paths], ignore_index=True)
panel["pulled_at"] = pd.to_datetime(panel["pulled_at"], utc=True)
panel["source_last_updated"] = pd.to_datetime(
    panel["source_last_updated"], dayfirst=True, errors="coerce", utc=True
)
fresh = (panel["pulled_at"] - panel["source_last_updated"]).dt.days <= 7
panel = panel[fresh].copy().sort_values(["site_id", "pulled_at"]).reset_index(drop=True)

# Build per-station diesel price series
station_series, station_meta = {}, {}
for site, group in panel.groupby("site_id"):
    g = group.sort_values("pulled_at")
    prices = g["B7"].dropna().values
    if len(prices) >= 5:
        station_series[site] = prices
        station_meta[site] = {
            "retailer": g["retailer"].iloc[0],
            "postcode": g["postcode"].iloc[0],
            "lat":      g["lat"].iloc[0],
            "lon":      g["lon"].iloc[0],
        }
print(f"Stations with >=5 obs: {len(station_series)}")

# Haversine distance
def haversine_km(lat1, lon1, lat2, lon2):
    R = 6371.0
    lat1, lon1, lat2, lon2 = map(np.radians, [lat1, lon1, lat2, lon2])
    dlat, dlon = lat2 - lat1, lon2 - lon1
    h = np.sin(dlat/2)**2 + np.cos(lat1) * np.cos(lat2) * np.sin(dlon/2)**2
    return 2 * R * np.arcsin(np.sqrt(h))

# Pair stations within MAX_DIST_KM
MAX_DIST_KM = 2.0
sites = list(station_series.keys())
pair_rows = []

for i, site_a in enumerate(sites):
    ma = station_meta[site_a]
    for site_b in sites[i+1:]:
        mb = station_meta[site_b]
        d = haversine_km(ma["lat"], ma["lon"], mb["lat"], mb["lon"])
        if d > MAX_DIST_KM:
            continue
        a, b = station_series[site_a], station_series[site_b]
        n = min(len(a), len(b))
        feats = extract_pair_features(a[-n:], b[-n:])
        if feats is None:
            continue
        feats.update({
            "site_a": site_a, "site_b": site_b,
            "retailer_a": ma["retailer"], "retailer_b": mb["retailer"],
            "lat_a": ma["lat"], "lon_a": ma["lon"],
            "lat_b": mb["lat"], "lon_b": mb["lon"],
            "distance_km": d, "n_obs": n,
        })
        pair_rows.append(feats)

pairs_df = pd.DataFrame(pair_rows)
X_real = pairs_df[PAIR_FEATURE_COLS].values
pairs_df["collusion_score"] = clf_pair.predict_proba(X_real)[:, 1]

print(f"\nPairs within {MAX_DIST_KM}km: {len(pairs_df)}")
print("\nScore distribution:")
print(pairs_df["collusion_score"].describe())

# Histogram
fig, ax = plt.subplots(figsize=(8, 4))
ax.hist(pairs_df["collusion_score"], bins=20, edgecolor="black", alpha=0.8)
ax.set_xlabel("Pair collusion score")
ax.set_ylabel("Number of pairs")
ax.set_title(f"Scores across {len(pairs_df)} station pairs within {MAX_DIST_KM}km")
ax.set_xlim(0, 1)
plt.tight_layout(); plt.show()

# Inspect top of the distribution
print("\nTop 10 highest-scoring pairs:")
print(pairs_df.sort_values("collusion_score", ascending=False)
      .head(10)[["retailer_a", "retailer_b", "distance_km", "n_obs", "collusion_score"]])

